---
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Holzbau Schulze – Webseiten-Konzept</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Libre+Franklin:wght@300;400;500;600;700;800;900&family=Big+Shoulders+Display:wght@400;600;700;800;900&display=swap" rel="stylesheet" />

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Holzbau Schulze",
    "description": "Zimmerei aus Heiningen – Dachsanierung, Dachdämmung, Holzfassaden und Dachfenster für die Region Göppingen.",
    "url": "https://www.holzbau-schulze.de",
    "telephone": "+4915222950536",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Hofstraße 1",
      "addressLocality": "Heiningen",
      "postalCode": "73092",
      "addressCountry": "DE"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 48.6630637,
      "longitude": 9.647369
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5",
      "reviewCount": "12"
    },
    "sameAs": ["https://maps.google.com/?cid=16126699474751242048"]
  }
  </script>

  <style>
    /* ── GATE ── */
    #gate {
      position: fixed;
      inset: 0;
      z-index: 9999;
      background: #0f0f0e;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      font-family: 'Libre Franklin', sans-serif;
      padding: 32px;
    }

    #gate.hidden { display: none; }

    .gate-dot {
      width: 8px;
      height: 8px;
      background: #fffe00;
      border-radius: 50%;
      margin-bottom: 40px;
    }

    .gate-title {
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #6b6b64;
      margin-bottom: 32px;
    }

    .gate-form {
      display: flex;
      flex-direction: column;
      gap: 12px;
      width: 100%;
      max-width: 280px;
    }

    .gate-input {
      background: #1c1c1a;
      border: 1px solid #2a2a27;
      color: #f0ede4;
      font-family: 'Libre Franklin', sans-serif;
      font-size: 15px;
      padding: 14px 16px;
      outline: none;
      transition: border-color 0.2s;
    }

    .gate-input:focus { border-color: #fffe00; }
    .gate-input::placeholder { color: #3a3a36; }

    .gate-btn {
      background: #fffe00;
      color: #111110;
      font-family: 'Libre Franklin', sans-serif;
      font-weight: 700;
      font-size: 12px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 14px;
      border: none;
      cursor: pointer;
    }

    .gate-error {
      font-size: 12px;
      color: rgba(255, 80, 80, 0.8);
      text-align: center;
      display: none;
    }

    .gate-error.visible { display: block; }

    /* ── STYLEGUIDE STYLES ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --yellow: #fffe00;
      --yellow-dim: rgba(255, 254, 0, 0.12);
      --dark: #111110;
      --dark-2: #1c1c1a;
      --dark-3: #2a2a27;
      --dark-4: #3a3a36;
      --mid: #6b6b64;
      --light: #c8c8bc;
      --cream: #f0ede4;
      --white: #ffffff;
      --font-display: 'Big Shoulders Display', sans-serif;
      --font-body: 'Libre Franklin', sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--dark);
      color: var(--cream);
      font-family: var(--font-body);
      font-size: 16px;
      line-height: 1.6;
    }

    .container { max-width: 960px; margin: 0 auto; padding: 0 32px; }

    section { padding: 80px 0; border-bottom: 1px solid var(--dark-3); }
    section:last-child { border-bottom: none; }

    .label {
      font-family: var(--font-body);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--yellow);
      margin-bottom: 12px;
    }

    h2 {
      font-family: var(--font-display);
      font-size: clamp(32px, 5vw, 52px);
      font-weight: 700;
      line-height: 1.05;
      color: var(--white);
      margin-bottom: 24px;
      text-transform: uppercase;
      letter-spacing: 0.02em;
    }

    h3 {
      font-family: var(--font-display);
      font-size: 22px;
      font-weight: 600;
      color: var(--white);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 12px;
    }

    p { color: var(--light); max-width: 640px; }
    p + p { margin-top: 12px; }

    header {
      background: var(--dark-2);
      border-bottom: 3px solid var(--yellow);
      padding: 20px 0;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      max-width: 960px;
      margin: 0 auto;
      padding: 0 32px;
    }

    .logo-mark { display: flex; align-items: center; gap: 12px; }

    .logo-img {
      height: 40px;
      width: auto;
      display: block;
    }


    .header-badge { font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--mid); }

    .hero { padding: 100px 0 80px; background: var(--dark-2); border-bottom: 1px solid var(--dark-3); }

    .hero-eyebrow {
      font-family: var(--font-body);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--yellow);
      margin-bottom: 20px;
    }

    .hero-title {
      font-family: var(--font-display);
      font-size: clamp(52px, 9vw, 96px);
      font-weight: 800;
      line-height: 0.95;
      text-transform: uppercase;
      letter-spacing: -0.01em;
      color: var(--white);
      margin-bottom: 32px;
    }

    .hero-title em { font-style: normal; color: var(--yellow); }

    .hero-sub { font-size: 18px; font-weight: 300; color: var(--light); max-width: 520px; line-height: 1.7; margin-bottom: 48px; }

    .hero-meta { display: flex; gap: 40px; flex-wrap: wrap; }

    .hero-meta-item span { display: block; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--mid); margin-bottom: 4px; }
    .hero-meta-item strong { font-size: 14px; font-weight: 600; color: var(--cream); }

    .video-mockup {
      margin-top: 56px;
      position: relative;
      aspect-ratio: 16/7;
      overflow: hidden;
      background: #111;
    }

    .video-mockup iframe {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 177.78vh;
      height: 56.25vw;
      min-width: 100%;
      min-height: 100%;
      pointer-events: none;
      border: none;
    }

    .video-placeholder {
      display: none;
      position: absolute;
      inset: 0;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 12px;
      background: linear-gradient(135deg, #1c1c1a 0%, #111110 100%);
    }

    .video-placeholder-icon {
      width: 48px;
      height: 48px;
      border: 2px solid var(--yellow);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .video-placeholder-icon::after {
      content: '';
      border-left: 16px solid var(--yellow);
      border-top: 10px solid transparent;
      border-bottom: 10px solid transparent;
      margin-left: 4px;
    }

    .video-placeholder span {
      font-size: 11px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--mid);
    }

    @media (max-width: 768px) {
      .video-mockup { aspect-ratio: 16/9; }
      .video-mockup iframe { display: none; }
      .video-placeholder { display: flex; }
    }

    .video-overlay {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 32px 40px;
      background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, transparent 100%);
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
    }

    .video-headline { font-family: var(--font-display); font-size: 28px; font-weight: 700; text-transform: uppercase; color: var(--white); }

    .video-cta {
      background: var(--yellow);
      color: var(--dark);
      font-family: var(--font-body);
      font-weight: 700;
      font-size: 13px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 16px 24px 12px;
      border: none;
      cursor: pointer;
      clip-path: polygon(0 8px, 50% 0, 100% 8px, 100% 100%, 0 100%);
    }

    .color-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 16px; margin-top: 32px; }
    .color-chip { border: 1px solid var(--dark-3); overflow: hidden; }
    .color-swatch { height: 80px; }
    .color-info { padding: 12px 14px; background: var(--dark-2); }
    .color-name { font-size: 12px; font-weight: 600; color: var(--white); margin-bottom: 2px; }
    .color-hex { font-size: 11px; color: var(--mid); font-family: monospace; }
    .color-role { font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--yellow); margin-top: 4px; }

    .type-samples { margin-top: 32px; display: flex; flex-direction: column; gap: 32px; }
    .type-sample { padding: 32px; background: var(--dark-2); border: 1px solid var(--dark-3); }
    .type-meta { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--mid); margin-bottom: 12px; }
    .type-display { font-family: var(--font-display); font-size: 64px; font-weight: 800; text-transform: uppercase; line-height: 1; color: var(--white); }
    .type-h1 { font-family: var(--font-display); font-size: 42px; font-weight: 700; text-transform: uppercase; color: var(--white); }
    .type-h2 { font-family: var(--font-display); font-size: 28px; font-weight: 600; text-transform: uppercase; color: var(--white); }
    .type-body { font-family: var(--font-body); font-size: 16px; font-weight: 400; line-height: 1.7; color: var(--light); }
    .type-label { font-family: var(--font-body); font-size: 11px; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--yellow); }

    .taglines { margin-top: 32px; display: flex; flex-direction: column; gap: 12px; }

    .tagline-option {
      padding: 24px 28px;
      background: var(--dark-2);
      border: 1px solid var(--dark-3);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
    }

    .tagline-option.preferred { border-color: var(--yellow); background: var(--yellow-dim); }
    .tagline-text { font-family: var(--font-display); font-size: 26px; font-weight: 700; text-transform: uppercase; color: var(--white); }
    .tagline-badge { font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; padding: 4px 10px; white-space: nowrap; }
    .tagline-badge.yes { background: var(--yellow); color: var(--dark); }
    .tagline-badge.alt { border: 1px solid var(--dark-4); color: var(--mid); }

    .why-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 32px; }
    @media (max-width: 640px) { .why-grid { grid-template-columns: 1fr; } }
    .why-card { padding: 28px; background: var(--dark-2); border: 1px solid var(--dark-3); }
    .why-card.highlight { border-color: var(--yellow); }
    .why-title { font-family: var(--font-display); font-size: 16px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--white); margin-bottom: 8px; }
    .why-text { font-size: 14px; line-height: 1.6; color: var(--light); max-width: none; }

    .vs-divider { margin: 32px 0 16px; display: flex; align-items: center; gap: 16px; }
    .vs-divider::before, .vs-divider::after { content: ''; flex: 1; height: 1px; background: var(--dark-3); }
    .vs-text { font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--mid); }

    .compare-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 8px; }
    .compare-cell { padding: 16px 20px; font-size: 13px; line-height: 1.5; }
    .compare-cell.bad { background: rgba(255,80,80,0.06); border: 1px solid rgba(255,80,80,0.15); color: var(--mid); }
    .compare-cell.good { background: var(--yellow-dim); border: 1px solid rgba(255,254,0,0.2); color: var(--cream); }
    .compare-label { font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 8px; }
    .compare-cell.bad .compare-label { color: rgba(255,80,80,0.6); }
    .compare-cell.good .compare-label { color: var(--yellow); }

    .phases { margin-top: 40px; display: flex; flex-direction: column; gap: 0; }
    .phase-item { display: grid; grid-template-columns: 80px 1fr; gap: 0; border: 1px solid var(--dark-3); margin-bottom: -1px; }
    .phase-num { background: var(--dark-3); display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 24px 16px; border-right: 1px solid var(--dark-4); }
    .phase-num-text { font-family: var(--font-display); font-size: 32px; font-weight: 800; color: var(--dark-4); line-height: 1; }
    .phase-num-label { font-size: 9px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--mid); margin-top: 4px; }
    .phase-item.active .phase-num { background: var(--yellow-dim); border-right-color: rgba(255,254,0,0.2); }
    .phase-item.active .phase-num-text { color: var(--yellow); }
    .phase-body { padding: 24px 28px; background: var(--dark-2); }
    .phase-title { font-family: var(--font-display); font-size: 18px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--white); margin-bottom: 6px; }
    .phase-desc { font-size: 14px; color: var(--light); line-height: 1.6; max-width: none; }
    .phase-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 12px; }
    .phase-tag { font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; padding: 3px 8px; border: 1px solid var(--dark-4); color: var(--mid); }
    .phase-tag.yellow { border-color: rgba(255,254,0,0.3); color: var(--yellow); }

    .seo-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 12px; margin-top: 32px; }
    .seo-item { padding: 20px; background: var(--dark-2); border: 1px solid var(--dark-3); }
    .seo-check { font-size: 12px; color: var(--yellow); font-weight: 700; margin-bottom: 6px; }
    .seo-title { font-size: 13px; font-weight: 600; color: var(--white); margin-bottom: 4px; }
    .seo-desc { font-size: 12px; color: var(--mid); line-height: 1.5; max-width: none; }

    .component-row { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 24px; align-items: flex-start; }
    .btn-primary {
      background: var(--yellow);
      color: var(--dark);
      font-family: var(--font-body);
      font-weight: 700;
      font-size: 13px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 22px 28px 14px;
      border: none;
      cursor: pointer;
      display: inline-block;
      clip-path: polygon(0 10px, 50% 0, 100% 10px, 100% 100%, 0 100%);
      transition: clip-path 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), background 0.2s ease;
    }
    .btn-primary:hover {
      clip-path: polygon(0 26px, 50% 0, 100% 26px, 100% 100%, 0 100%);
      background: #ffff33;
    }
    .btn-secondary {
      background: transparent;
      color: var(--yellow);
      font-family: var(--font-body);
      font-weight: 700;
      font-size: 13px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 22px 28px 14px;
      border: none;
      cursor: pointer;
      display: inline-block;
      outline: 2px solid var(--yellow);
      outline-offset: -2px;
      clip-path: polygon(0 10px, 50% 0, 100% 10px, 100% 100%, 0 100%);
      transition: clip-path 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .btn-secondary:hover {
      clip-path: polygon(0 26px, 50% 0, 100% 26px, 100% 100%, 0 100%);
    }
    .btn-ghost {
      background: transparent;
      color: var(--light);
      font-family: var(--font-body);
      font-weight: 600;
      font-size: 13px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 13px 28px;
      border: 1px solid var(--dark-4);
      cursor: pointer;
      display: inline-block;
    }

    .quote-card { margin-top: 32px; padding: 32px; background: var(--dark-2); border-left: 3px solid var(--yellow); max-width: 600px; }
    .quote-text { font-size: 16px; font-style: italic; color: var(--cream); line-height: 1.7; margin-bottom: 16px; }
    .quote-author { font-size: 12px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--yellow); }

    footer { padding: 40px 0; background: var(--dark-2); border-top: 1px solid var(--dark-3); }
    .footer-inner { max-width: 960px; margin: 0 auto; padding: 0 32px; display: flex; justify-content: space-between; align-items: center; }
    .footer-text { font-size: 12px; color: var(--mid); }
    .footer-note { font-size: 11px; color: var(--dark-4); text-align: right; }
  </style>
</head>
<body>

  <!-- PASSWORD GATE -->
  <div id="gate">
    <div class="gate-dot"></div>
    <div class="gate-title">Holzbau Schulze · Webseiten-Konzept</div>
    <form class="gate-form" id="gate-form">
      <input
        class="gate-input"
        type="password"
        id="pw-input"
        placeholder="Passwort eingeben"
        autocomplete="current-password"
      />
      <button class="gate-btn" type="submit">Zugang</button>
      <div class="gate-error" id="gate-error">Falsches Passwort</div>
    </form>
  </div>

  <!-- CONTENT (shown after correct password) -->
  <div id="content">

    <div style="background:var(--yellow);padding:10px 32px;text-align:center;">
      <span style="font-family:var(--font-body);font-size:13px;font-weight:600;color:var(--dark);letter-spacing:0.04em;">
        Dieses Dokument ist kein fertiges Webseiten-Design — es ist ein Styleguide und Prozessvorschlag zur gemeinsamen Abstimmung.
      </span>
    </div>

    <header>
      <div class="header-inner">
        <div class="logo-mark">
          <img class="logo-img" src="/assets/holzbau-schulze-logo.png" alt="Holzbau Schulze" />
        </div>
        <div class="header-badge">Webseiten-Konzept · Entwurf</div>
      </div>
    </header>

    <section class="hero">
      <div class="container">
        <img src="/assets/holzbau-schulze-logo.png" alt="Holzbau Schulze" style="height:80px;width:auto;display:block;margin-bottom:32px;" />
        <div class="hero-eyebrow">Webseiten-Konzept für Holzbau Schulze · Heiningen</div>
        <h1 class="hero-title">Ehrlich<br>beraten.<br><em>Sauber</em><br>gebaut.</h1>
        <p class="hero-sub">
          Eine neue Webseite die zeigt, wofür Lukas Schulze steht:
          handwerkliche Qualität, ehrliche Beratung und Zuverlässigkeit,
          auf die man sich verlassen kann.
        </p>
        <div class="hero-meta">
          <div class="hero-meta-item"><span>Kunde</span><strong>Lukas Schulze</strong></div>
          <div class="hero-meta-item"><span>Region</span><strong>Heiningen / Göppingen</strong></div>
          <div class="hero-meta-item"><span>Technologie</span><strong>Astro + TailwindCSS</strong></div>
          <div class="hero-meta-item"><span>Status</span><strong>Konzeptphase</strong></div>
        </div>
        <div style="margin:48px 0;padding:28px 32px;background:var(--dark-2);border:1px solid var(--dark-3);border-left:3px solid var(--yellow);">
          <div style="font-family:var(--font-body);font-size:11px;font-weight:600;letter-spacing:0.15em;text-transform:uppercase;color:var(--yellow);margin-bottom:16px;">Ziel dieser Webseite</div>
          <div style="display:flex;flex-direction:column;gap:12px;">
            <div style="display:flex;align-items:flex-start;gap:16px;">
              <span style="font-family:var(--font-display);font-size:13px;font-weight:700;background:var(--yellow);color:var(--dark);padding:2px 8px;white-space:nowrap;margin-top:1px;">Primär</span>
              <span style="font-size:15px;color:var(--cream);line-height:1.5;">Neue Kundenanfragen generieren — per Kontaktformular oder direktem Anruf. Jeder Seitenbesucher soll einen klaren Weg zur Kontaktaufnahme haben.</span>
            </div>
            <div style="display:flex;align-items:flex-start;gap:16px;">
              <span style="font-family:var(--font-display);font-size:13px;font-weight:700;border:1px solid var(--dark-4);color:var(--mid);padding:2px 8px;white-space:nowrap;margin-top:1px;">Sekundär</span>
              <span style="font-size:15px;color:var(--light);line-height:1.5;">Sichtbarkeit bei Google für lokale Suchanfragen (»Zimmerer Heiningen«, »Dachsanierung Göppingen«) — und langfristig als regionaler Experte in KI-Suchen wie ChatGPT oder Google AI Overview erscheinen.</span>
            </div>
          </div>
        </div>

        <div class="video-mockup">
          <iframe
            src="https://www.youtube.com/embed/ZsRMm8Xdn6M?autoplay=1&mute=1&loop=1&playlist=ZsRMm8Xdn6M&controls=0&rel=0&modestbranding=1&playsinline=1"
            allow="autoplay; encrypted-media"
            allowfullscreen
            title="Drohnenvideo Dachsanierung"
          ></iframe>
          <div class="video-placeholder">
            <div class="video-placeholder-icon"></div>
            <span>Video läuft auf Desktop</span>
          </div>
          <div class="video-overlay">
            <div class="video-headline">Zimmerei Schulze · Heiningen</div>
            <button class="video-cta">Jetzt anfragen</button>
          </div>
        </div>

