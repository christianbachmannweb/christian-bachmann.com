<script>
  // Check session storage first
  if (sessionStorage.getItem('schulze_auth') === 'true') {
    document.getElementById('gate').classList.add('hidden');
    document.getElementById('content').style.display = 'block';
  }

  document.getElementById('gate-form').addEventListener('submit', function(e) {
    e.preventDefault();
    const val = document.getElementById('pw-input').value.toLowerCase().trim();
    if (val === 'schulze') {
      sessionStorage.setItem('schulze_auth', 'true');
      document.getElementById('gate').classList.add('hidden');
      document.getElementById('content').style.display = 'block';
    } else {
      document.getElementById('gate-error').classList.add('visible');
    }
  });
</script>

